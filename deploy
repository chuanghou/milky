
# compile one module, -pl --projects
mvn clean compile -pl demo

# -am also make
mvn clean compile -am -pl demo

#-D define property test => unit test class failIfNoTest make empty tests also worked
mvn clean test -am -Dtest=BasicTest -pl demo -DfailIfNoTests=false

# in linux or macOs the quotation is not necessary, but windows, garbage
mvn clean install '-DskipTests' '-Dgpg.skip'

# 发布脚本（配置写在 scripts/mvn-deploy.ps1 / mvn-deploy.sh 顶部）：
#   .\scripts\mvn-deploy.ps1
#   ./scripts/mvn-deploy.sh

mvn clean deploy '-DskipTests' '-Dgpg.skip'

mvn clean deploy "-DskipTests"

mvn clean install '-Dmaven.test.skip=true'

mvn dependency:copy-dependencies "-DexcludeGroupIds=com.stellariver.milky.demo"

1. mvn clean install '-DskipTests' '-Dgpg.skip' 刷新milky依赖到本地库
2. cd demo & mvn dependency:copy-dependencies "-DexcludeGroupIds=com.stellariver.milky"
3. 上传 demo/target ---> 服务器/bin目录，上传 demo/dependency ---> dependency 目录


